# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg2://loc:loc@localhost:5432/loc

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000"]

# ── AI / Embeddings (R3 EXP-6) ───────────────────────────────────────────────
# Leave blank to run keyword-only search; set to enable pgvector hybrid search
OPENAI_API_KEY=

# ── Email / Lead notifications (STAY-4) ──────────────────────────────────────
# Leave blank to log inquiries only (no email sent)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@loctravels.com
EMAIL_TO=

# ── pgAdmin (dev only) ────────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@loc.dev
PGADMIN_PASSWORD=admin
