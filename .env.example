# ---- Postgres ----
POSTGRES_USER=loc
POSTGRES_PASSWORD=loc
POSTGRES_DB=loc

# ---- Backend ----
# Inside Docker the host is the service name `db` / `redis` (already wired in compose).
# +psycopg2 driver suffix is required by SQLAlchemy — do not remove it.
DATABASE_URL=postgresql+psycopg2://loc:loc@db:5432/loc
REDIS_URL=redis://redis:6379/0
CORS_ORIGINS=http://localhost:3000
ENV=development

# ---- Frontend ----
# NEXT_PUBLIC_API_URL  → baked into the JS bundle; used by the browser for direct API calls.
#                        Points to the public-facing host (localhost in dev, domain in prod).
NEXT_PUBLIC_API_URL=http://localhost:8000

# API_INTERNAL_URL → server-side only (Next.js API proxy routes, SSR).
#                    Inside Docker this hits the backend service by name, not localhost.
#                    Never prefixed NEXT_PUBLIC_ — never exposed to the browser.
API_INTERNAL_URL=http://backend:8000

# ---- Phase 2 (semantic search) — leave blank until enabled ----
EMBEDDINGS_API_KEY=
EMBEDDINGS_MODEL=text-embedding-3-small
